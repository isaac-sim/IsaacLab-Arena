{
    "datagen": {
        "description": "Hemisphere datagen for all robolab graph-spec scenes (maple_table + droid).",
        "output_dir": "/datasets/nvblox_next/droid_data/arena/openpi/robolab_v1",
        "width": 640,
        "height": 480,
        "mesh_sample_spacing": 0.01,
        "store_normals": false,
        "store_flow3d": false,
        "store_float_type": "float16",
        "frame_stride": 2,
        "max_recorded_frames": 200,
        "color_resolution": [640, 480],
        "depth_resolution": [640, 480],
        "flow2d_resolution": [640, 480],
        "semantic_resolution": [640, 480],
        "cameras_hemisphere": {
            "num_cameras": 10,
            "radius": 1.5,
            "center": [
                0.0,
                0.0,
                0.3
            ],
            "front_dir": [
                1.0,
                0.0,
                0.0
            ],
            "focal_length_mm": 14,
            "min_height": 0.1,
            "randomize_per_episode": true
        }
    },
    "jobs": [
        {
            "name": "bagel_plate_banana_bowl_linked",
            "arena_env_args": {
                "enable_cameras": true,
                "num_envs": 1,
                "environment": "isaaclab_arena_environments/robolab/bagel_plate_banana_bowl_linked.yaml"
            },
            "num_episodes": 10,
            "policy_type": "isaaclab_arena_openpi.policy.pi0_remote_policy.Pi0RemotePolicy",
            "policy_config_dict": {
                "policy_variant": "pi05",
                "policy_device": "cuda:0",
                "remote_host": "127.0.0.1",
                "remote_port": 8000,
                "openpi_embodiment_adapter": "droid"
            },
            "variations": {
                "light": {
                    "hdr_image": {
                        "enabled": true
                    }
                }
            }
        },
        {
            "name": "bin_mug_marker_bowl_linked",
