# CloudXR config for headset optical hand tracking (Quest 3, Pico 4 Ultra, etc.).
# Start the runtime with:
#   python -m isaacteleop.cloudxr --cloudxr-install-dir=/cloudxr \
#       --cloudxr-env-config=/path/to/IsaacLab-Arena/handtracking.env
#
# Use "false" (not "0"): Isaac Teleop's env loader skips falsy values, so 0 never
# reaches the CloudXR runtime subprocess and hand tracking stays disabled.
NV_CXR_ENABLE_PUSH_DEVICES=false
