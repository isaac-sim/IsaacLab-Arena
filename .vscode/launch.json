        {
            "name": "Policy Runner",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "--visualizer", "kit",
                "--policy_type", "zero_action",
                "--num_steps", "100",
                "gr1_open_microwave",
                "--embodiment", "gr1_pink"
            ]
        },

        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },


    ]
}
